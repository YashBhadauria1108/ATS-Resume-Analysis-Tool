# ========================================
#   ATS Project - Environment Variables
# ========================================

# MongoDB - Choose ONE option:

# Option 1: Local MongoDB Compass
MONGO_URI=mongodb://127.0.0.1:27017/ats_project

# Option 2: MongoDB Atlas (Cloud) - uncomment & replace:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ats_project?retryWrites=true&w=majority

# Google Gemini AI Key - Get from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret (change this to a random string)
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# Port (optional)
PORT=5000

# Frontend URL for CORS (for Vercel deployment)
FRONTEND_URL=http://localhost:3000
